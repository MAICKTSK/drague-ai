# Base de données
DATABASE_URL="postgresql://user:password@localhost:5432/seduction_ai"

# Auth
JWT_SECRET="change_moi_en_production"
JWT_EXPIRES_IN="7d"

# Compte propriétaire — À NE JAMAIS mettre de vraies valeurs ici (ce fichier est un template public).
# Mets les vraies valeurs uniquement dans ton .env local, jamais commité.
OWNER_EMAIL="ton-email@example.com"
OWNER_APPLE_EMAIL="ton-email-icloud@example.com"

# Envoi du code de vérification à 5 chiffres par email (laisse SMTP_HOST vide en dev :
# le code s'affichera simplement dans la console du serveur).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Drague.ai <no-reply@drague.ai>"

# Sign in with Google
GOOGLE_CLIENT_ID="....apps.googleusercontent.com"

# Sign in with Apple
APPLE_CLIENT_ID="com.tonapp.service"

# IA
ANTHROPIC_API_KEY="sk-ant-..."

# Stripe (Visa, Mastercard, American Express) — pour les paiements des utilisateurs uniquement
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Mobile Money pan-africain (Flutterwave)
FLW_SECRET_KEY="..."
FLW_WEBHOOK_SECRET_HASH="..."

# Paiement et retrait crypto (NowPayments)
NOWPAYMENTS_API_KEY="..."
NOWPAYMENTS_IPN_SECRET="..."

# Divers
PORT=4000
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
